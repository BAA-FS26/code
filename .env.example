# .env.example
#
# Copy this file to .env and fill in your values.
# .env is gitignored and should never be committed.
#
# W&B is fully optional. The pipeline runs without it and saves results
# locally. Only set these if you want to enable W&B logging (--wandb flag).

# Your W&B username or team name (required if using --wandb)
WANDB_ENTITY=your_wandb_username

# W&B project name (optional — defaults to "synthetic-data-eval")
# WANDB_PROJECT=synthetic-data-eval
