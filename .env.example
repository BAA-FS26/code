# Copy this file to .env if you want to use Weights & Biases (W&B) logging.
# If you only use the default local JSON logging workflow, you do not need a
# .env file at all.

# W&B logging is optional and only needed when passing --wandb to pipeline scripts.
# It also requires the optional W&B dependency to be installed.

# Required for --wandb
WANDB_ENTITY=your_wandb_username_or_team

# Optional: overrides the default project name from constants.py
# WANDB_PROJECT=synthetic-data-eval

# You can also export these variables directly in your shell instead of using
# a .env file.